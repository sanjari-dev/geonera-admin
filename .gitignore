# ── Dependency Directories ───────────────────────────────────────────────────
node_modules/
**/node_modules/
jspm_packages/
web_modules/

# ── Build & Production Outputs ────────────────────────────────────────────────
dist/
**/dist/
build/
**/build/
out/
**/out/
.next/
.nuxt/
.cache/
.parcel-cache/
.eslintcache
.yarn-clean
.pnp/
.pnp.js

# ── Environment & Secrets ─────────────────────────────────────────────────────
# Ignore all env files by default to prevent credential leakage
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
**/*.env
**/*.env.local
**/*.env.development.local
**/*.env.test.local
**/*.env.production.local

# Allow committed example templates
!.env.example
!**/ .env.example

# ── Logs & Debugging ─────────────────────────────────────────────────────────
logs/
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── IDEs, Editors, & System Files ─────────────────────────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
.DS_Store
.DS_Store?
ehthumbs.db
Thumbs.db

# ── Temporary & Scratch Files ─────────────────────────────────────────────────
tmp/
**/tmp/
temp/
**/temp/
.temp/
**/.temp/
scratch/
**/scratch/
.claude/
.gemini/

